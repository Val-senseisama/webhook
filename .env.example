# ---- Go API ----
PORT=8080
ENVIRONMENT=development

# Supabase: Settings > Database > Connection string
# Use Transaction mode (port 6543) for the pooler, Direct (port 5432) for workers
DATABASE_POOLER_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_DIRECT_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require

# Fixed tenant UUID — seed this into the DB on first run
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# ---- Next.js Dashboard ----
NEXT_PUBLIC_API_URL=http://localhost:8080  # local dev only; set API_URL in Vercel for prod
API_URL=https://your-api.example.com       # server-side only (Vercel env var)
WEBHOOK_API_KEY=your_api_key_here          # server-side only; NEXT_PUBLIC_API_KEY still works locally

# Supabase (for Realtime, optional)
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
